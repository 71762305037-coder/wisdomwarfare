# ==========================================
# ----- WISDOM WARFARE BACKEND -----
# Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#   npm start
# ==========================================

# ==========================================
# ----- SERVER CONFIGURATION -----
# ==========================================

# Node environment (development, production, test)
NODE_ENV=development

# Port the server should run on
# For Render: Leave empty (Render assigns via PORT env var)
# For local development: Use 4001
PORT=4001

# Server base URL for links in emails/redirects
# For production: Your actual domain (e.g., https://your-app.onrender.com)
# For local: http://localhost:4001
SERVER_BASE=http://localhost:4001

# Frontend base URL for game invites in emails
# For production: Your Vercel/deployed frontend URL
# For local: http://localhost:3000
FRONTEND_BASE=http://localhost:3000

# Client base URL (same as FRONTEND_BASE)
CLIENT_BASE_URL=http://localhost:3000

# ==========================================
# ----- DATABASE CONFIGURATION -----
# ==========================================

# Full Database URL (recommended)
# Format: mysql://user:password@host:port/database
# Example: mysql://root:password123@localhost:3306/wisdomwarfare
# For local: Leave empty for defaults
# For Render: Use the MySQL database URL provided by Render
DATABASE_URL=

# ==========================================
# ----- EMAIL CONFIGURATION -----
# ==========================================

# Choose ONE email provider:
# 1. Brevo (Sendinblue) - Recommended
# 2. SMTP - Alternative

# BREVO CONFIGURATION
# Get API key from: https://dashboard.brevo.com/account/api-keys
BREVO_API_KEY=

# Brevo sender email (must be verified in Brevo)
BREVO_SENDER_EMAIL=noreply@example.com

# Name to display as sender
BREVO_SENDER_NAME=Wisdom Warfare

# Email to use in From header
EMAIL_FROM=noreply@example.com

# ==========================================
# ----- SMTP CONFIGURATION (Alternative) -----
# ==========================================

# Leave empty if using Brevo API
# Required only if using SMTP:

# SMTP Server host (e.g., smtp.gmail.com)
SMTP_HOST=

# SMTP Server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Username (usually your email)
SMTP_USER=

# SMTP Password (use app-specific password if 2FA enabled)
SMTP_PASS=

# Use TLS encryption (true for TLS, false for no encryption)
SMTP_SECURE=true

# ==========================================
# ----- NOTES FOR DIFFERENT ENVIRONMENTS -----
# ==========================================

# LOCAL DEVELOPMENT:
# - NODE_ENV=development
# - PORT=4001
# - SERVER_BASE=http://localhost:4001
# - FRONTEND_BASE=http://localhost:3000
# - CLIENT_BASE_URL=http://localhost:3000
# - DATABASE_URL= (leave empty - uses local MySQL defaults)
# - Email services optional

# RENDER DEPLOYMENT:
# - NODE_ENV=production
# - PORT= (empty - Render assigns it)
# - SERVER_BASE=https://your-app.onrender.com
# - FRONTEND_BASE=https://your-frontend.vercel.app
# - CLIENT_BASE_URL=https://your-frontend.vercel.app
# - DATABASE_URL=mysql://user:pass@host:port/db (from Render MySQL)
# - BREVO_API_KEY=your_key (or SMTP settings)

# DOCKER DEPLOYMENT:
# - NODE_ENV=production
# - PORT=4001
# - SERVER_BASE=http://your-domain.com
# - FRONTEND_BASE=https://your-frontend.com
# - CLIENT_BASE_URL=https://your-frontend.com
# - DATABASE_URL=mysql://root:password@db-service:3306/wisdomwarfare
# - Email provider configured

# ==========================================
# ----- IMPORTANT SECURITY NOTES -----
# ==========================================

# NEVER commit .env to Git
# Add to .gitignore: .env, .env.*.local

# For production:
# - Use strong passwords (minimum 16 characters)
# - Use app-specific email passwords, not account passwords
# - Set NODE_ENV=production
# - Use HTTPS URLs (https://, not http://)
# - Keep API keys secret and never share

# Render-specific:
# - DATABASE_URL is injected by Render from connected database
# - PORT is injected by Render automatically
# - Only override if explicitly needed

# ==========================================
