# Wisdom Warfare Frontend - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================

# Node environment
# Options: development, production
NODE_ENV=development

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API base URL
# Used for all REST API calls (both quiz and crossword)
# Local development: http://localhost:4001
# Render production: https://your-app.onrender.com
REACT_APP_API_BASE=http://localhost:4001

# ============================================================================
# NOTES
# ============================================================================

# Single Server, Single API Base:
# - Both quiz and crossword games use the same backend PORT (4001)
# - No separate CROSSWORD_API_BASE or CROSSWORD_PORT needed
# - All API calls go through REACT_APP_API_BASE
# - Socket.IO connections also use the same server URL

# If you want custom Socket.IO server URL (optional):
# - Leave REACT_APP_SERVER_URL unset to use REACT_APP_API_BASE
# - Or explicitly set REACT_APP_SERVER_URL if needed for special cases


# Frontend port (for development)
PORT=3000

# Public URL (Render will set this automatically)
PUBLIC_URL=/

# ============================================================================
# FEATURES & SETTINGS
# ============================================================================

# Enable debug logging
REACT_APP_DEBUG=false

# Multiplayer settings
# Max concurrent games a user can play
REACT_APP_MAX_CONCURRENT_GAMES=5

# Socket.IO reconnection settings
REACT_APP_SOCKET_RECONNECT_ATTEMPTS=10
REACT_APP_SOCKET_RECONNECT_DELAY_MS=1000

# Game timeouts
REACT_APP_GAME_EVENT_TIMEOUT_MS=30000
REACT_APP_RECONNECT_TIMEOUT_MS=60000

# ============================================================================
# MONITORING & ANALYTICS (Optional)
# ============================================================================

# Google Analytics (if using)
REACT_APP_GA_MEASUREMENT_ID=your_ga_id_here

# Sentry Error Tracking (if using)
REACT_APP_SENTRY_DSN=your_sentry_dsn_here

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Enable browser devtools for Redux (development only)
REACT_APP_REDUX_DEVTOOLS=false

# Enable Socket.IO debug logs (verbose)
REACT_APP_SOCKET_DEBUG=false

# Simulate network lag (ms) - for testing
REACT_APP_NETWORK_LAG_MS=0

# ============================================================================
# NOTES
# ============================================================================

# 1. DEPLOYMENT TO RENDER:
#    - Set REACT_APP_SERVER_URL to your Render backend URL
#    - Export in Render Environment Variables dashboard
#    - Frontend will automatically use window.location.origin in production
#
# 2. LOCAL DEVELOPMENT:
#    - npm start will use localhost:4001
#    - Make sure backend is running: cd backend && npm start
#
# 3. ENVIRONMENT VARIABLES:
#    - Prefix with REACT_APP_ to make available in browser
#    - Non-prefixed variables are for Node.js build process only
#    - Never commit .env file to git (add to .gitignore)
#
# 4. MULTIPLAYER SCALING:
#    - SocketManager handles up to REACT_APP_MAX_CONCURRENT_GAMES
#    - Each game code is isolated via Socket.IO rooms
#    - Heartbeat keeps connections alive (prevents Render 55s timeout)
#
# 5. FIREBASECONFIG:
#    - Only needed if using Firebase authentication
#    - Remove these if using other auth methods
#
# 6. SOCKET.IO SETTINGS:
#    - Auto-reconnect enabled for network resilience
#    - Event timeout prevents hanging promises
#    - Offline event queueing (sends when reconnected)
